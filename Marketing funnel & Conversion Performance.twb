        <calculation class='tableau' formula='SUM([Calculation_0602000836276229]) / SUM([Calculation_0602000836612103])' />
      </column>
      <column caption='Engaged Visitors' datatype='integer' name='[Calculation_0770501917736960]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [ProductRelated] &gt; 0 THEN 1 ELSE 0 END' />
      </column>
      <column caption='High Intent Visitors' datatype='integer' name='[Calculation_0770501917843457]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [ProductRelated] &gt; 5 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Funnel Stage' datatype='string' name='[Calculation_0770501919346690]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0602000836276229] = 1 THEN &quot;Customers&quot;&#13;&#10;ELSEIF [Calculation_0770501917843457] = 1 THEN &quot;High Intent Visitors&quot;&#13;&#10;ELSEIF [Calculation_0770501917736960] = 1 THEN &quot;Engaged Visitors&quot;&#13;&#10;ELSE &quot;Visitors&quot;&#13;&#10;END' />
      </column>
      <column caption='Visitor to Engaged Conversion' datatype='real' default-format='p0.00%' name='[Calculation_0770502229671939]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0770501917736960]) / SUM([Calculation_0602000836612103])' />
      </column>
      <column caption='Engaged to High Intent Conversion' datatype='real' default-format='p0.00%' name='[Calculation_0770502229975044]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0770501917843457]) / SUM([Calculation_0770501917736960])' />
      </column>
      <column caption='High Intent to Customer Conversion' datatype='real' default-format='p0.00%' name='[Calculation_0770502230351877]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0602000836276229]) / SUM([Calculation_0770501917843457])' />
      </column>
      <column caption='Overall Conversion Rate' datatype='real' default-format='p0.00%' name='[Calculation_0770502230683654]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0602000836276229]) / SUM([Calculation_0602000836612103])' />
      </column>
      <column caption='Customers' datatype='real' name='[Calculation_0770502236626951]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0602000836276229]) / SUM([Calculation_0602000836612103])' />
      </column>
      <column caption='Drop-off after Engagement' datatype='real' default-format='p0.00%' name='[Calculation_0770502237818888]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - (SUM([Calculation_0770501917736960]) / SUM([Calculation_0602000836612103]))' />
      </column>
      <column caption='Drop-off before Purchase' datatype='real' default-format='p0.00%' name='[Calculation_0770502237929481]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - (SUM([Calculation_0602000836276229]) / SUM([Calculation_0770501917843457]))' />
